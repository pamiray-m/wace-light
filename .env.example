# WACE Light — configuration. Copy to backend/.env and fill in. Never commit .env.
#
# REQUIRED — a 32+ char random secret to sign your session tokens:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
AOS_JWT_SECRET=

# REQUIRED — base64 of 32 random bytes; seals your stored LLM key (AES-256-GCM):
#   python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
AOS_VAULT_KEY=

# Database — SQLite by default (a file next to the backend). Point at Postgres for more.
AOS_DB_URL=sqlite:///./wace_light.db

# Your AI: WACE Light is bring-your-own-key. Set your Anthropic key here to start
# with the platform default, OR leave blank and add it in-app (sealed at rest).
#   ANTHROPIC_API_KEY=sk-ant-...
# Force the local Claude Code CLI bridge instead of the API (uses your Claude
# subscription via `claude -p`): AOS_LLM_BACKEND=cli
